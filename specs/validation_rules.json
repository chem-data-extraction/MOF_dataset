{
  "validation_version": "0.2.0",
  "rules": [
    {
      "rule_id": "files_exist_core",
      "target": "repository",
      "rule_type": "required_files",
      "severity": "error",
      "description": "Core project files, final parsed extraction files, processed tables, schemas, and scripts must exist."
    },
    {
      "rule_id": "extracted_folder_only_final_tables",
      "target": "data/extracted",
      "rule_type": "allowed_files",
      "severity": "error",
      "description": "The extracted folder must contain only the four final parsed CSV files."
    },
    {
      "rule_id": "processed_tables_exist",
      "target": "data/processed",
      "rule_type": "file_exists",
      "severity": "error",
      "description": "Final processed material and measurement tables must exist."
    },
    {
      "rule_id": "schema_columns_match",
      "target": "data/processed",
      "rule_type": "schema_columns",
      "severity": "error",
      "description": "Processed table columns must match specs/mof_materials_schema.json and specs/adsorption_measurements_schema.json."
    },
    {
      "rule_id": "record_id_unique",
      "target": "adsorption_measurements.record_id",
      "rule_type": "unique",
      "severity": "error",
      "description": "Measurement record_id values must be non-empty and unique."
    },
    {
      "rule_id": "mof_id_unique",
      "target": "mof_materials.mof_id",
      "rule_type": "unique",
      "severity": "error",
      "description": "Material mof_id values must be non-empty and unique."
    },
    {
      "rule_id": "measurement_mof_id_fk",
      "target": "adsorption_measurements.mof_id",
      "rule_type": "foreign_key",
      "severity": "error",
      "description": "Every measurement mof_id must exist in mof_materials.csv."
    },
    {
      "rule_id": "source_id_in_source_map",
      "target": "source_id",
      "rule_type": "foreign_key",
      "severity": "warning",
      "description": "source_id should appear in specs/source_map.json."
    },
    {
      "rule_id": "capacity_value_numeric",
      "target": "adsorption_measurements.capacity_value",
      "rule_type": "numeric_or_null",
      "severity": "error",
      "description": "capacity_value must be numeric or empty/null."
    }
  ]
}
