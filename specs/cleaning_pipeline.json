{
  "pipeline_version": "0.3.1",
  "inputs": [
    "data/extracted/pdf_parsed_records.csv",
    "data/extracted/pdf_parsed_materials.csv",
    "data/extracted/web_parsed_records.csv",
    "data/extracted/web_parsed_materials.csv"
  ],
  "outputs": [
    "data/processed/mof_materials.csv",
    "data/processed/adsorption_measurements.csv",
    "data/processed/dataset.csv"
  ],
  "steps": [
    {
      "step_id": "merge_sources",
      "operation": "concatenate",
      "description": "Join parsed PDF and web measurement records with parsed MOF material descriptors.",
      "input_files": [
        "data/extracted/pdf_parsed_records.csv",
        "data/extracted/pdf_parsed_materials.csv",
        "data/extracted/web_parsed_records.csv",
        "data/extracted/web_parsed_materials.csv"
      ],
      "output_file": "data/interim/merged_records.csv"
    },
    {
      "step_id": "standardize_units",
      "operation": "unit_standardization",
      "description": "Keep every numeric value paired with its unit column and document any conversions.",
      "fields": [
        "pore_size",
        "pore_size_unit",
        "surface_area_BET",
        "surface_area_BET_unit",
        "pore_volume",
        "pore_volume_unit",
        "temperature",
        "temperature_unit",
        "pressure",
        "pressure_unit",
        "capacity_value",
        "capacity_unit"
      ],
      "output_file": "data/interim/merged_records.csv"
    },
    {
      "step_id": "standardize_mof_identity",
      "operation": "material_identity_cleanup",
      "description": "Use mof_id, MOF_name, chemical_formula, metal_node, organic_linker, pore descriptors, and source identifiers to distinguish MOF materials in the material table.",
      "fields": [
        "mof_id",
        "MOF_name",
        "chemical_formula",
        "metal_node",
        "organic_linker",
        "pore_size",
        "surface_area_BET",
        "pore_volume",
        "source_material_id"
      ],
      "output_file": "data/interim/merged_records.csv"
    },
    {
      "step_id": "standardize_source_location",
      "operation": "source_locator_cleanup",
      "description": "Collapse source-specific locator fields such as page, figure, table_or_figure, articleSource, and isotherm JSON filenames into source_location and extraction_method.",
      "fields": [
        "source_location",
        "extraction_method",
        "isotherm_id",
        "source_url"
      ],
      "output_file": "data/interim/merged_records.csv"
    },
    {
      "step_id": "standardize_missing_values",
      "operation": "missing_value_cleanup",
      "description": "Map NA, N/A, -, and empty strings to null-like values for pandas export.",
      "fields": [
        "capacity_value",
        "capacity_unit",
        "source_id",
        "notes"
      ],
      "output_file": "data/interim/merged_records.csv"
    },
    {
      "step_id": "deduplicate_records",
      "operation": "deduplicate",
      "description": "Remove duplicate rows sharing record_id.",
      "fields": [
        "record_id",
        "mof_id",
        "gas_type",
        "temperature",
        "pressure",
        "capacity_value",
        "source_id"
      ],
      "output_file": "data/interim/merged_records.csv"
    },
    {
      "step_id": "export_flat_dataset",
      "operation": "export",
      "description": "Write a flat compatibility dataset for validators and simple preview use.",
      "input_files": [
        "data/interim/merged_records.csv"
      ],
      "output_file": "data/processed/dataset.csv"
    },
    {
      "step_id": "export_normalized_tables",
      "operation": "normalize_tables",
      "description": "Split merged records into a compact MOF material table and a compact adsorption measurement table keyed by mof_id.",
      "input_files": [
        "data/interim/merged_records.csv"
      ],
      "output_files": [
        "data/processed/mof_materials.csv",
        "data/processed/adsorption_measurements.csv"
      ]
    },
    {
      "step_id": "validate_schema",
      "operation": "validation",
      "description": "Run rules in specs/validation_rules.json via scripts/validate_project.py.",
      "input_files": [
        "data/processed/mof_materials.csv",
        "data/processed/adsorption_measurements.csv"
      ],
      "output_file": "reports/practice_05_cleaning_publication.md"
    }
  ],
  "output": "data/processed/dataset.csv"
}
